---
// Header component
---
<header class="navbar">
  <div class="container">
    <div class="navbar__inner">
      <!-- Logo -->
      <a href="/" class="navbar__logo">
        MUNDO 3D
      </a>

      <!-- Search bar (visual only, non-functional) -->
      <div class="navbar__search">
        <input type="text" placeholder="Buscar productos..." aria-label="Buscar productos" class="navbar__search-input" />
        <button type="button" aria-label="Buscar" class="navbar__search-btn">
          <svg class="navbar__icon" viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg" style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; image-rendering: pixelated;">
            <rect x="3" y="2" width="8" height="1" />
            <rect x="3" y="9" width="8" height="1" />
            <rect x="2" y="3" width="1" height="6" />
            <rect x="11" y="3" width="1" height="6" />
            <rect x="9" y="9" width="2" height="2" />
            <rect x="11" y="11" width="2" height="2" />
            <rect x="13" y="13" width="2" height="2" />
          </svg>
        </button>
      </div>

      <!-- Navigation -->
      <nav class="navbar__list">
        <ul class="navbar__list--left">
          <li class="navbar__item"><a href="/products" class="navbar__link">Productos</a></li>
          <li class="navbar__item admin-only" style="display: none;"><a href="/admin/products" class="navbar__link">Administrar productos</a></li>
        </ul>

        <ul class="navbar__list--right">
          <!-- Guest Navigation -->
          <li class="navbar__item guest-only"><a href="/login" class="navbar__link">Iniciar sesión</a></li>
          <li class="navbar__item guest-only"><a href="/register" class="navbar__link">Registrarse</a></li>

          <!-- User Navigation (Authenticated) -->
          <li class="nav-item user-only" style="display: none;">
            <div class="nav-item__trigger">
              <img id="navbar-avatar" src="/img/users/default-avatar.png" width="32" height="32" alt="Avatar" style="border-radius: 50%; object-fit: cover;" />
              <span class="navbar__greeting" id="navbar-greeting">Hola</span>
              <ul class="nav-item__dropdown">
                <li><a href="/profile">Mi perfil</a></li>
                <li><a href="#" id="navbar-logout">Cerrar sesión</a></li>
              </ul>
            </div>
          </li>

          <!-- Cart badge -->
          <li class="navbar__item">
            <a href="/cart" class="cart-link" aria-label="Carrito de compras">
              <svg class="navbar__icon" viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg" style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; image-rendering: pixelated; margin-right: 4px;">
                <rect x="1" y="3" width="3" height="1" />
                <rect x="3" y="4" width="1" height="6" />
                <rect x="4" y="4" width="11" height="1" />
                <rect x="4" y="5" width="1" height="4" />
                <rect x="5" y="9" width="10" height="1" />
                <rect x="14" y="5" width="1" height="4" />
                <rect x="6" y="6" width="2" height="2" opacity="0.5" />
                <rect x="10" y="6" width="2" height="2" opacity="0.5" />
                <rect x="5" y="10" width="8" height="1" />
                <rect x="5" y="11" width="2" height="2" />
                <rect x="11" y="11" width="2" height="2" />
              </svg>
              Carrito
              <span class="cart-link__badge" id="navbar-cart-badge" style="display: none;">0</span>
            </a>
          </li>

          <!-- Theme toggle -->
          <li class="navbar__item">
            <button class="theme-toggle-btn" id="theme-toggle" aria-label="Toggle Theme">
              <span class="theme-toggle-btn__icon">◐</span>
            </button>
          </li>

          <!-- CRT toggle -->
          <li class="navbar__item">
            <button class="crt-toggle-btn" id="crt-toggle" aria-label="Toggle CRT Effect">
              <span class="crt-toggle-btn__icon">📺</span>
            </button>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</header>

<script>
  import { cartItems, CartService } from '../domains/cart';

  // Dynamic User Session and UI state hydration
  function updateSessionUI() {
    const token = localStorage.getItem('token');
    const userJson = localStorage.getItem('user');
    
    const guestElements = document.querySelectorAll('.guest-only');
    const userElements = document.querySelectorAll('.user-only');
    const adminElements = document.querySelectorAll('.admin-only');
    const greetingEl = document.getElementById('navbar-greeting');
    const avatarEl = document.getElementById('navbar-avatar') as HTMLImageElement | null;

    if (token && userJson) {
      try {
        const user = JSON.parse(userJson);
        
        // Hide guest links
        guestElements.forEach(el => (el as HTMLElement).style.display = 'none');
        
        // Show authenticated links
        userElements.forEach(el => (el as HTMLElement).style.display = 'block');
        
        // Update greeting and avatar
        if (greetingEl) {
          greetingEl.textContent = `Hola ${user.firstName || user.FirstName || 'Usuario'}`;
        }
        if (avatarEl && user.image) {
          avatarEl.src = `/img/users/${user.image}`;
        } else if (avatarEl && user.Image) {
          avatarEl.src = `/img/users/${user.Image}`;
        }

        // Show the admin nav link only for ADMIN (1) or STAFF (3) — see
        // Role in domains/auth/adapters/auth.adapter.ts. This is a
        // presentation-layer convenience only (visual-admin-hiding spec):
        // it MUST NOT be relied upon as the security boundary. The API's
        // requireRoles guard is authoritative for authorization regardless
        // of what this check renders.
        const isAdminOrStaff = user.idRole === 1 || user.idRole === 3;
        adminElements.forEach(el => {
          (el as HTMLElement).style.display = isAdminOrStaff ? 'block' : 'none';
        });
      } catch (e) {
        console.error('Error parsing user storage:', e);
        // Clear corrupt storage
        localStorage.removeItem('token');
        localStorage.removeItem('user');
        resetToGuestUI();
      }
    } else {
      resetToGuestUI();
    }
  }

  function resetToGuestUI() {
    const guestElements = document.querySelectorAll('.guest-only');
    const userElements = document.querySelectorAll('.user-only');
    const adminElements = document.querySelectorAll('.admin-only');
    
    guestElements.forEach(el => (el as HTMLElement).style.display = 'block');
    userElements.forEach(el => (el as HTMLElement).style.display = 'none');
    adminElements.forEach(el => (el as HTMLElement).style.display = 'none');
  }

  // Handle Logout
  const logoutBtn = document.getElementById('navbar-logout');
  if (logoutBtn) {
    logoutBtn.addEventListener('click', (e) => {
      e.preventDefault();
      localStorage.removeItem('token');
      localStorage.removeItem('user');
      CartService.clearCart(); // Clear cart state properly
      window.location.href = '/login';
    });
  }

  // Theme Toggle Logic
  function applyTheme(theme: string) {
    if (theme === 'light') {
      document.documentElement.setAttribute('data-theme', 'light');
    } else {
      document.documentElement.setAttribute('data-theme', 'dark');
    }

    const toggleBtnIcon = document.querySelector('.theme-toggle-btn__icon');
    if (toggleBtnIcon) {
      toggleBtnIcon.textContent = theme === 'light' ? '☀️' : '🌙';
    }
  }

  const toggleBtn = document.getElementById('theme-toggle');
  const currentTheme = localStorage.getItem('theme') || 'dark';
  applyTheme(currentTheme);

  if (toggleBtn) {
    toggleBtn.addEventListener('click', () => {
      const activeTheme = document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
      const newTheme = activeTheme === 'light' ? 'dark' : 'light';
      localStorage.setItem('theme', newTheme);
      applyTheme(newTheme);
    });
  }

  // CRT Toggle Logic
  function applyCrtTheme(preference: string) {
    const crtToggleBtnIcon = document.querySelector('.crt-toggle-btn__icon');
    if (preference === 'enabled') {
      document.documentElement.classList.add('crt-theme-active');
      if (crtToggleBtnIcon) {
        crtToggleBtnIcon.textContent = '📺';
      }
    } else {
      document.documentElement.classList.remove('crt-theme-active');
      if (crtToggleBtnIcon) {
        crtToggleBtnIcon.textContent = '🔌';
      }
    }
  }

  const crtToggleBtn = document.getElementById('crt-toggle');
  const currentCrtPreference = localStorage.getItem('retro-theme-preference') || 'enabled';
  applyCrtTheme(currentCrtPreference);

  if (crtToggleBtn) {
    crtToggleBtn.addEventListener('click', () => {
      const isCurrentlyActive = document.documentElement.classList.contains('crt-theme-active');
      const newPreference = isCurrentlyActive ? 'disabled' : 'enabled';
      localStorage.setItem('retro-theme-preference', newPreference);
      applyCrtTheme(newPreference);
    });
  }

  // Initial Run and Event Listeners
  updateSessionUI();
  
  // Listen for storage updates (in case session changes in another tab)
  window.addEventListener('storage', updateSessionUI);
  
  // Listen for custom login/logout/session events to update immediately
  window.addEventListener('session-changed', updateSessionUI);

  // --- Cart badge sync ---
  function updateCartBadge(): void {
    const badge = document.getElementById('navbar-cart-badge');
    if (!badge) return;
    const items = cartItems.get();
    const count = items.length;
    if (count > 0) {
      badge.textContent = String(count);
      badge.style.display = 'inline-block';
    } else {
      badge.style.display = 'none';
    }
  }

  // Load initial cart and listen to changes
  CartService.loadCartFromStorage();
  updateCartBadge();

  cartItems.subscribe(() => {
    updateCartBadge();
  });
</script>


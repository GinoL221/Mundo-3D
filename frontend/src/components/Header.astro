---
// Header component
---
<header class="navbar">
  <div class="container">
    <div class="navbar__inner">
      <!-- Logo -->
      <a href="/" class="navbar__logo">
        MUNDO 3D
      </a>

      <!-- Search bar (visual only, non-functional) -->
      <div class="navbar__search">
        <input type="text" placeholder="Buscar productos..." aria-label="Buscar productos" class="navbar__search-input" />
        <button type="button" aria-label="Buscar" class="navbar__search-btn">
          <svg class="navbar__icon" viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg" style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; image-rendering: pixelated;">
            <rect x="3" y="2" width="8" height="1" />
            <rect x="3" y="9" width="8" height="1" />
            <rect x="2" y="3" width="1" height="6" />
            <rect x="11" y="3" width="1" height="6" />
            <rect x="9" y="9" width="2" height="2" />
            <rect x="11" y="11" width="2" height="2" />
            <rect x="13" y="13" width="2" height="2" />
          </svg>
        </button>
      </div>

      <!-- Navigation -->
      <nav class="navbar__list">
        <ul class="navbar__list--left">
          <li class="navbar__item"><a href="/products" class="navbar__link">Productos</a></li>
          <li class="navbar__item admin-only" style="display: none;"><a href="/admin/products" class="navbar__link">Administrar productos</a></li>
        </ul>

        <ul class="navbar__list--right">
          <!-- Guest Navigation -->
          <li class="navbar__item guest-only"><a href="/login" class="navbar__link">Iniciar sesión</a></li>
          <li class="navbar__item guest-only"><a href="/register" class="navbar__link">Registrarse</a></li>

          <!-- User Navigation (Authenticated) -->
          <li class="nav-item user-only" style="display: none;">
            <div class="nav-item__trigger">
              <img id="navbar-avatar" src="/img/users/default-avatar.png" width="32" height="32" alt="Avatar" style="border-radius: 50%; object-fit: cover;" />
              <span class="navbar__greeting" id="navbar-greeting">Hola</span>
              <ul class="nav-item__dropdown">
                <li><a href="/profile">Mi perfil</a></li>
                <li><a href="#" id="navbar-logout">Cerrar sesión</a></li>
              </ul>
            </div>
          </li>

          <!-- Cart badge -->
          <li class="navbar__item">
            <a href="/cart" class="cart-link" aria-label="Carrito de compras">
              <svg class="navbar__icon" viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg" style="width: 16px; height: 16px; display: inline-block; vertical-align: middle; image-rendering: pixelated; margin-right: 4px;">
                <rect x="1" y="3" width="3" height="1" />
                <rect x="3" y="4" width="1" height="6" />
                <rect x="4" y="4" width="11" height="1" />
                <rect x="4" y="5" width="1" height="4" />
                <rect x="5" y="9" width="10" height="1" />
                <rect x="14" y="5" width="1" height="4" />
                <rect x="6" y="6" width="2" height="2" opacity="0.5" />
                <rect x="10" y="6" width="2" height="2" opacity="0.5" />
                <rect x="5" y="10" width="8" height="1" />
                <rect x="5" y="11" width="2" height="2" />
                <rect x="11" y="11" width="2" height="2" />
              </svg>
              Carrito
              <span class="cart-link__badge" id="navbar-cart-badge" style="display: none;">0</span>
            </a>
          </li>

          <!-- Theme toggle -->
          <li class="navbar__item">
            <button class="theme-toggle-btn" id="theme-toggle" aria-label="Toggle Theme">
              <span class="theme-toggle-btn__icon">◐</span>
            </button>
          </li>

          <!-- CRT toggle -->
          <li class="navbar__item">
            <button class="crt-toggle-btn" id="crt-toggle" aria-label="Toggle CRT Effect">
              <span class="crt-toggle-btn__icon">📺</span>
            </button>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</header>

<script>
  import { initializeCartBadge } from '../scripts/cartBadge';
  import { initializeCrtToggle } from '../scripts/crtToggle';
  import { initializeSessionUI } from '../scripts/sessionUI';
  import { initializeThemeToggle } from '../scripts/themeToggle';

  initializeSessionUI(document, window, localStorage);
  initializeThemeToggle(document, localStorage);
  initializeCrtToggle(document, localStorage);
  initializeCartBadge(document);
</script>

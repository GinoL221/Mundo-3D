---
import Layout from '../layouts/Layout.astro';
import { ProductCard } from '../domains/products';
---

<Layout title="Mundo 3D - Inicio">
  <!-- Carousel -->
  <section class="carousel carousel--lcd" id="homepage-carousel">
    <div class="carousel__container">
      <div class="carousel__slide">
        <a href="/products">
          <div class="carousel__text glow">Modelado y fabricación 3D</div>
        </a>
      </div>
      <div class="carousel__slide">
        <a href="/aboutUs">
          <div class="carousel__text glow">Calidad premium garantizada</div>
        </a>
      </div>
      <div class="carousel__slide">
        <a href="/help">
          <div class="carousel__text glow">Pedí tu cotización</div>
        </a>
      </div>
    </div>
    <button class="carousel__prev" aria-label="Slide anterior">&#10094;</button>
    <button class="carousel__next" aria-label="Slide siguiente">&#10095;</button>
    <div class="carousel__indicators">
      <button class="carousel__indicator active" data-slide="0" aria-label="Ir al slide 1"></button>
      <button class="carousel__indicator" data-slide="1" aria-label="Ir al slide 2"></button>
      <button class="carousel__indicator" data-slide="2" aria-label="Ir al slide 3"></button>
    </div>
  </section>

  <!-- Feature Strip -->
  <section class="feature-strip">
    <div class="feature-strip__tile">
      <h3 class="feature-strip__title">Calidad Premium</h3>
      <p class="feature-strip__description">Materiales de alta resistencia para cada proyecto.</p>
    </div>
    <div class="feature-strip__tile">
      <h3 class="feature-strip__title">Envío Rápido</h3>
      <p class="feature-strip__description">Recibí tu pedido en tiempo récord, preparado con cuidado.</p>
    </div>
    <div class="feature-strip__tile">
      <h3 class="feature-strip__title">Soporte 24/7</h3>
      <p class="feature-strip__description">Estamos para vos en cada paso del proceso.</p>
    </div>
  </section>

  <!-- Dynamic product section -->
  <main class="index">
    <div id="products-container">
      <p id="index-loading-msg" style="text-align:center; padding:2rem;">Cargando productos...</p>
      <div id="products-content" style="display: none;">
        <h2 class="page-heading">Nuestros Seleccionados</h2>
        <div class="product-grid" id="product-grid-container"></div>
      </div>
    </div>
  </main>

  <ProductCard />

  <template id="empty-state-template">
    <div class="empty-state">
      <img src="/images/illustrations/empty-state.svg" alt="Próximamente" class="empty-state-img" style="image-rendering: pixelated;" />
      <h2>Próximamente</h2>
      <p>Estamos preparando productos increíbles para vos.</p>
    </div>
  </template>

  <template id="error-state-template">
    <div class="empty-state">
      <img src="/images/illustrations/empty-state.svg" alt="Error" class="empty-state-img" style="image-rendering: pixelated;" />
      <h2>Próximamente</h2>
      <p>Estamos preparando productos increíbles para vos.</p>
    </div>
  </template>
</Layout>

<script>
  import { API_URL } from '../config';
  import { adaptAPIProducts, getCategoryImg, isPlaceholderImage } from '../domains/products';
  import type { APIProduct } from '../domains/products';

  // Carousel logic
  (function initCarousel() {
    const container = document.querySelector('.carousel__container') as HTMLElement | null;
    const slides = document.querySelectorAll('.carousel__slide');
    const indicators = document.querySelectorAll('.carousel__indicator');
    let current = 0;
    let interval: ReturnType<typeof setInterval>;

    function goTo(idx: number): void {
      current = (idx + slides.length) % slides.length;
      if (container) container.style.transform = `translateX(-${current * 100}%)`;
      indicators.forEach((ind, i) => {
        ind.classList.toggle('active', i === current);
      });
    }

    document.querySelector('.carousel__prev')?.addEventListener('click', () => {
      goTo(current - 1);
      resetInterval();
    });
    document.querySelector('.carousel__next')?.addEventListener('click', () => {
      goTo(current + 1);
      resetInterval();
    });
    indicators.forEach((btn) => {
      btn.addEventListener('click', () => {
        const slide = Number((btn as HTMLElement).dataset.slide);
        goTo(slide);
        resetInterval();
      });
    });

    function resetInterval(): void {
      clearInterval(interval);
      interval = setInterval(() => goTo(current + 1), 5000);
    }

    resetInterval();
  })();

  // Dynamic product grid
  async function loadProducts(): Promise<void> {
    const container = document.getElementById('products-container');
    const loadingMsg = document.getElementById('index-loading-msg');
    const contentEl = document.getElementById('products-content');
    const gridContainer = document.getElementById('product-grid-container');
    if (!container) return;

    try {
      const res = await fetch(`${API_URL}/api/products`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const resData = (await res.json()) as { products: APIProduct[] };
      const rawProducts = resData?.products || [];
      const products = adaptAPIProducts(rawProducts);

      if (loadingMsg) loadingMsg.remove();

      if (products.length === 0) {
        const emptyTemp = document.getElementById('empty-state-template') as HTMLTemplateElement | null;
        if (emptyTemp) {
          const clone = emptyTemp.content.cloneNode(true);
          container.appendChild(clone);
        }
        return;
      }

      const cardTemp = document.getElementById('product-card-template') as HTMLTemplateElement | null;
      if (!cardTemp || !gridContainer || !contentEl) return;

      const fragment = document.createDocumentFragment();
      for (const product of products) {
        const clone = cardTemp.content.cloneNode(true) as DocumentFragment;

        const link = clone.querySelector('.product-card-link') as HTMLAnchorElement | null;
        const img = clone.querySelector('.product-card__category-img') as HTMLImageElement | null;
        const name = clone.querySelector('.product-card-name') as HTMLElement | null;
        const price = clone.querySelector('.product-card-price') as HTMLElement | null;

        const catImg = getCategoryImg(product.category);
        const article = clone.querySelector('article') as HTMLElement | null;
        if (article) article.dataset.category = catImg;

        if (link) {
          link.href = `/product?id=${product.id}`;
        }
        if (img) {
          const catName = product.category;
          const catImg = getCategoryImg(catName);
          const isPlaceholder = isPlaceholderImage(product.image);
          if (isPlaceholder) {
            img.src = `/images/illustrations/${catImg}.svg`;
            img.alt = catName;
            img.classList.add('product-card__category-img--pixelart');
          } else {
            img.src = `/img/products/${product.image}`;
            img.alt = product.name;
            img.classList.remove('product-card__category-img--pixelart');
          }
          img.addEventListener('error', () => {
            img.src = '/images/illustrations/Otras.svg';
            img.classList.add('product-card__category-img--pixelart');
          });
        }
        if (name) {
          name.textContent = product.name;
        }
        if (price) {
          price.textContent = `$${product.price}`;
        }

        fragment.appendChild(clone);
      }

      gridContainer.appendChild(fragment);
      contentEl.style.display = 'block';
    } catch {
      if (loadingMsg) loadingMsg.remove();
      if (contentEl) contentEl.remove();
      const errorTemp = document.getElementById('error-state-template') as HTMLTemplateElement | null;
      if (errorTemp) {
        const clone = errorTemp.content.cloneNode(true);
        container.appendChild(clone);
      }
    }
  }

  loadProducts();
</script>


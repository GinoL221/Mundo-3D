---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Iniciar Sesión - Mundo 3D">
  <main class="form-layout">
    <div class="form-card">
      <form id="login-form" class="form-card__form" novalidate>
        <h2>Iniciar Sesión</h2>

        <div id="login-error" class="form-card__error" style="display: none;"></div>

        <label for="email">Correo Electrónico:</label>
        <input
          type="email"
          id="email"
          name="email"
          class="form-card__input"
          autocomplete="email"
          required
        />

        <label for="password">Contraseña:</label>
        <input
          type="password"
          id="password"
          name="password"
          class="form-card__input"
          autocomplete="current-password"
          required
        />

        <label for="remember" class="form-card__checkbox">
          <input type="checkbox" id="remember" name="remember" /> Recuérdame
        </label>

        <div class="form-card__actions">
          <button type="submit" id="login-btn" class="form-card__btn">Iniciar Sesión</button>
        </div>

        <p style="margin-top: 1rem; text-align: center; font-size: 0.9rem;">
          ¿No tenés cuenta? <a href="/register">Registrate</a>
        </p>
      </form>
    </div>
  </main>
</Layout>

<script>
  const form = document.getElementById('login-form') as HTMLFormElement | null;
  const errorBox = document.getElementById('login-error') as HTMLElement | null;
  const loginBtn = document.getElementById('login-btn') as HTMLButtonElement | null;

  function showError(msg: string): void {
    if (errorBox) {
      errorBox.textContent = msg;
      errorBox.style.display = 'block';
    }
  }

  function hideError(): void {
    if (errorBox) {
      errorBox.style.display = 'none';
    }
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    hideError();

    const emailEl = document.getElementById('email') as HTMLInputElement | null;
    const passwordEl = document.getElementById('password') as HTMLInputElement | null;

    const email = emailEl?.value?.trim() || '';
    const password = passwordEl?.value || '';

    if (!email || !password) {
      showError('Por favor completá todos los campos.');
      return;
    }

    if (loginBtn) loginBtn.disabled = true;

    try {
      const res = await fetch('http://localhost:3000/api/users/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password }),
      });

      const data = await res.json();

      if (!res.ok) {
        showError(data.error || data.message || 'Error al iniciar sesión.');
        return;
      }

      // Store session
      localStorage.setItem('token', data.token);
      if (data.user) {
        localStorage.setItem('user', JSON.stringify(data.user));
      }

      // Notify header and other components
      window.dispatchEvent(new CustomEvent('session-changed'));

      // Redirect to homepage
      window.location.href = '/';
    } catch {
      showError('No se pudo conectar con el servidor. Intentá de nuevo.');
    } finally {
      if (loginBtn) loginBtn.disabled = false;
    }
  });
</script>

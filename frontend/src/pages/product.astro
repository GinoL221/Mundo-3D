---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Detalle del Producto - Mundo 3D">
  <h2 class="product-detail__title" id="product-title">Cargando...</h2>
  <main class="product-detail__main">
    <div class="product-detail__card">
      <a href="/products" class="product-detail__back-link">← Volver a productos</a>
      <div id="product-content" style="display:none;">
        <img id="product-img" src="" alt="" class="product-detail__image" />
        <section class="product-detail__info">
          <h3 id="product-name"></h3>
          <p class="price price--lg" id="product-price"></p>
          <p id="product-description"></p>
          <button id="add-to-cart-btn" class="product-detail__action product-detail__action--secondary">
            AGREGAR AL CARRITO
          </button>
          <a href="/cart" class="product-detail__action">IR AL CARRITO</a>
        </section>
        <div class="product-specs">
          <h4 class="product-specs__title">Especificaciones 3D</h4>
          <table class="product-specs__table">
            <tbody>
              <tr>
                <td class="product-specs__label">Material</td>
                <td class="product-specs__value" id="product-material">-</td>
              </tr>
              <tr>
                <td class="product-specs__label">Dimensiones</td>
                <td class="product-specs__value" id="product-dimensions">-</td>
              </tr>
              <tr>
                <td class="product-specs__label">Acabado</td>
                <td class="product-specs__value" id="product-finish">-</td>
              </tr>
              <tr>
                <td class="product-specs__label">Tiempo de Producción</td>
                <td class="product-specs__value" id="product-production">-</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
      <div id="product-error" style="display:none;">
        <p>No se pudo cargar el producto. <a href="/products">Volver al catálogo</a></p>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { API_URL } from '../config';
  import { adaptAPIProduct } from '../domains/products';
  import type { APIProduct } from '../domains/products';
  import { CartService } from '../domains/cart';

  /**
   * Reads the product id from the URL.
   * Supports both:
   *  - /product?id=123  (query param strategy, used by Astro SSG)
   *  - /product/123     (path segment, handled by dev server rewrite if configured)
   */
  function getProductId(): string | null {
    const searchParams = new URLSearchParams(window.location.search);
    const fromQuery = searchParams.get('id');
    if (fromQuery) return fromQuery;

    // Fallback: try to extract from path segments
    const parts = window.location.pathname.split('/').filter(Boolean);
    if (parts.length >= 2 && parts[0] === 'product') {
      return parts[1];
    }
    return null;
  }

  async function loadProduct(): Promise<void> {
    const productId = getProductId();
    if (!productId) {
      showError();
      return;
    }

    try {
      const res = await fetch(`${API_URL}/api/product/${productId}`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      const rawProduct = await res.json() as APIProduct;
      const product = adaptAPIProduct(rawProduct);

      const titleEl = document.getElementById('product-title');
      const imgEl = document.getElementById('product-img') as HTMLImageElement | null;
      const nameEl = document.getElementById('product-name');
      const priceEl = document.getElementById('product-price');
      const descEl = document.getElementById('product-description');
      const contentEl = document.getElementById('product-content');
      const addBtn = document.getElementById('add-to-cart-btn');

      const materialEl = document.getElementById('product-material');
      const dimensionsEl = document.getElementById('product-dimensions');
      const finishEl = document.getElementById('product-finish');
      const productionEl = document.getElementById('product-production');

      if (titleEl) titleEl.textContent = product.name;
      const CATEGORY_IMAGES: Record<string, string> = {
        Figura: 'Figura',
        Busto: 'Busto',
        Llavero: 'Llavero',
        Máscara: 'Mascara',
        Otras: 'Otras',
      };

      function getCategoryImg(categoryName: string): string {
        return CATEGORY_IMAGES[categoryName] || 'Otras';
      }

      if (imgEl) {
        const isPlaceholder = !product.image || product.image === 'productoSinImagen.png' || product.image === 'productoSinImagen.svg';
        const catImg = getCategoryImg(product.category);
        if (isPlaceholder) {
          imgEl.src = `/images/illustrations/${catImg}.svg`;
          imgEl.classList.add('product-detail__image--pixelart');
        } else {
          imgEl.src = `/img/products/${product.image}`;
          imgEl.classList.remove('product-detail__image--pixelart');
        }
        imgEl.alt = product.name;
        imgEl.addEventListener('error', () => {
          imgEl.src = `/images/illustrations/${catImg}.svg`;
          imgEl.classList.add('product-detail__image--pixelart');
        });
      }
      if (nameEl) nameEl.textContent = product.name;
      if (priceEl) priceEl.textContent = `Precio: $${product.price}`;
      if (descEl) descEl.textContent = product.description;

      if (materialEl) materialEl.textContent = product.material;
      if (finishEl) finishEl.textContent = product.finish;
      if (productionEl) productionEl.textContent = product.productionTime;

      if (dimensionsEl) {
        const hasHeight = product.height && product.height !== 'A consultar';
        const hasWidth = product.width && product.width !== 'A consultar';
        const hasDepth = product.depth && product.depth !== 'A consultar';

        if (hasHeight || hasWidth || hasDepth) {
          dimensionsEl.textContent = `H: ${product.height} | W: ${product.width} | D: ${product.depth}`;
        } else {
          dimensionsEl.textContent = 'A consultar';
        }
      }

      if (contentEl) contentEl.style.display = '';
      document.title = `${product.name} - Mundo 3D`;

      addBtn?.addEventListener('click', () => {
        CartService.addToCart(product);
        const btn = addBtn as HTMLButtonElement;
        const original = btn.textContent;
        btn.textContent = '✔ AGREGADO';
        btn.disabled = true;
        setTimeout(() => { btn.textContent = original; btn.disabled = false; }, 2000);
      });
    } catch (err) {
      console.error('Error loading product:', err);
      showError();
    }
  }

  function showError(): void {
    const errorEl = document.getElementById('product-error');
    const titleEl = document.getElementById('product-title');
    if (errorEl) errorEl.style.display = 'block';
    if (titleEl) titleEl.textContent = 'Producto no encontrado';
  }

  loadProduct();
</script>


---
// Presentational template for client-side product card cloning
---
<template id="product-card-template">
  <article class="product-card">
    <a class="product-card-link" href="">
      <div class="product-card__image-panel">
        <img src="" alt="" class="product-card__category-img" />
      </div>
      <div class="product-card__body">
        <h3 class="product-card-name"></h3>
        <p class="price product-card-price"></p>
      </div>
    </a>
  </article>
</template>

<%- include('../partials/head') %>
<title>Mundo 3D - Registro</title>
</head>

<body>
  <%- include('../partials/header') %>

  <main class="form-layout">
    <div class="form-card--medium">
      <form action="/users?_csrf=<%= csrfToken %>" method="POST" enctype="multipart/form-data" class="form-card__form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <h2>Registro</h2>

        <label for="firstName">Nombre:</label>
        <input type="text" id="firstName" name="firstName" class="form-card__input <%= locals.errors && errors.firstName? 'form-card__input--invalid' : null %>" value="<%= locals.oldData ? oldData.firstName : null %>" />
        <% if(locals.errors && errors.firstName){ %>
        <div class="form-card__error">
          <%= errors.firstName.msg %>
        </div>
        <% } %>

        <label for="lastName">Apellido:</label>
        <input type="text" id="lastName" name="lastName" class="form-card__input <%= locals.errors && errors.lastName? 'form-card__input--invalid' : null %>" value="<%= locals.oldData ? oldData.lastName : null %>">
        <% if(locals.errors && errors.lastName){ %> <div class=" form-card__error">
          <%= errors.lastName.msg %>
        </div>
        <% } %>

        <label for="email">Correo Electrónico:</label>
        <input type="email" id="email" name="email" class="form-card__input <%= locals.errors && errors.email? 'form-card__input--invalid' : null %>" value="<%= locals.oldData ? oldData.email : null %>">
        <% if(locals.errors && errors.email){ %>
        <div class="form-card__error">
          <%= errors.email.msg %>
        </div>
        <% } %>

        <label for="password">Contraseña:</label>
        <input type="password" id="password" name="password" class="form-card__input <%= locals.errors && errors.password? 'form-card__input--invalid' : null %>">
        <% if(locals.errors && errors.password){ %>
        <div class=" form-card__error">
          <%= errors.password.msg %>
        </div>
        <% } %>

        <label for="confirmPassword">Confirmar contraseña:</label>
        <input type="password" id="confirmPassword" name="confirmPassword" class="form-card__input <%= locals.errors && errors.confirmPassword? 'form-card__input--invalid' : null %>">
        <% if(locals.errors && errors.confirmPassword){ %>
        <div class="form-card__error">
          <%= errors.confirmPassword.msg %>
        </div>
        <% } %>

        <ul id="password-checks" class="pw-checks" style="display: none; list-style: none; padding: 0; margin: 8px 0; font-size: 0.9rem;">
          <li id="check-length" style="color: #ea4335; margin-bottom: 4px; display: flex; align-items: center; gap: 6px;">
            <span class="icon" style="font-weight: bold;">✘</span> Entre 6 y 16 caracteres
          </li>
          <li id="check-match" style="color: #ea4335; margin-bottom: 4px; display: flex; align-items: center; gap: 6px;">
            <span class="icon" style="font-weight: bold;">✘</span> Las contraseñas coinciden
          </li>
        </ul>

        <label for="image">Imagen de perfil:</label>
        <input type="file" id="image" name="image">
        <% if(locals.errors && errors.image){ %>
        <div class="form-card__error">
          <%= errors.image.msg %>
        </div>
        <% } %>

        <div class="form-card__actions">
          <button type="reset" class="form-card__btn">Borrar</button>
          <button type="submit" class="form-card__btn">Registrarse</button>
        </div>
      </form>
    </div>
  </main>

  <%- include('../partials/footer') %>

  <script>
    const passwordInput = document.getElementById('password');
    const confirmPasswordInput = document.getElementById('confirmPassword');
    const checksContainer = document.getElementById('password-checks');

    const lengthCheck = document.getElementById('check-length');
    const lengthIcon = lengthCheck.querySelector('.icon');

    const matchCheck = document.getElementById('check-match');
    const matchIcon = matchCheck.querySelector('.icon');

    function updateChecks() {
      const password = passwordInput.value;
      const confirmPassword = confirmPasswordInput.value;

      if (password.length > 0 || confirmPassword.length > 0) {
        checksContainer.style.display = 'block';
      } else {
        checksContainer.style.display = 'none';
        return;
      }

      const isLengthValid = password.length >= 6 && password.length <= 16;
      if (isLengthValid) {
        lengthCheck.style.color = '#34a853';
        lengthIcon.textContent = '✔';
      } else {
        lengthCheck.style.color = '#ea4335';
        lengthIcon.textContent = '✘';
      }

      const isMatchValid = password.length > 0 && password === confirmPassword;
      if (isMatchValid) {
        matchCheck.style.color = '#34a853';
        matchIcon.textContent = '✔';
      } else {
        matchCheck.style.color = '#ea4335';
        matchIcon.textContent = '✘';
      }
    }

    passwordInput.addEventListener('input', updateChecks);
    passwordInput.addEventListener('change', updateChecks);
    confirmPasswordInput.addEventListener('input', updateChecks);
    confirmPasswordInput.addEventListener('change', updateChecks);

    // Initial check on load (for values that might be present immediately)
    updateChecks();

    // Fallback checks to catch browser autofill which can occur slightly after load
    setTimeout(updateChecks, 100);
    setTimeout(updateChecks, 500);
  </script>
</body>

</html>

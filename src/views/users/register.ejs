<%- include('../partials/head') %>
<title>Mundo 3D - Registro</title>
</head>

<body>
  <%- include('../partials/header') %>

  <main class="form-layout">
    <div class="form-card--medium">
      <form action="/users?_csrf=<%= csrfToken %>" method="POST" enctype="multipart/form-data" class="form-card__form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <h2>Registro</h2>

        <label for="firstName">Nombre:</label>
        <input type="text" id="firstName" name="firstName" class="form-card__input <%= locals.errors && errors.firstName? 'form-card__input--invalid' : null %>" value="<%= locals.oldData ? oldData.firstName : null %>" />
        <% if(locals.errors && errors.firstName){ %>
        <div class="form-card__error">
          <%= errors.firstName.msg %>
        </div>
        <% } %>

        <label for="lastName">Apellido:</label>
        <input type="text" id="lastName" name="lastName" class="form-card__input <%= locals.errors && errors.lastName? 'form-card__input--invalid' : null %>" value="<%= locals.oldData ? oldData.lastName : null %>">
        <% if(locals.errors && errors.lastName){ %> <div class=" form-card__error">
          <%= errors.lastName.msg %>
        </div>
        <% } %>

        <label for="email">Correo Electrónico:</label>
        <input type="email" id="email" name="email" class="form-card__input <%= locals.errors && errors.email? 'form-card__input--invalid' : null %>" value="<%= locals.oldData ? oldData.email : null %>">
        <% if(locals.errors && errors.email){ %>
        <div class="form-card__error">
          <%= errors.email.msg %>
        </div>
        <% } %>

        <label for="password">Contraseña:</label>
        <input type="password" id="password" name="password" maxlength="32" class="form-card__input <%= locals.errors && errors.password? 'form-card__input--invalid' : null %>">
        <% if(locals.errors && errors.password){ %>
        <div class=" form-card__error">
          <%= errors.password.msg %>
        </div>
        <% } %>
        <ul class="pw-checks" style="list-style: none; padding: 0; margin: 6px 0 0; font-size: 0.9rem; display: none;" id="password-strength-checks">
          <li id="check-uppercase" style="color: #ea4335; display: flex; align-items: center; gap: 6px;">
            <span class="icon" style="font-weight: bold;">✘</span> Al menos 1 mayúscula
          </li>
          <li id="check-number" style="color: #ea4335; display: flex; align-items: center; gap: 6px;">
            <span class="icon" style="font-weight: bold;">✘</span> Al menos 1 número
          </li>
          <li id="check-special" style="color: #ea4335; display: flex; align-items: center; gap: 6px;">
            <span class="icon" style="font-weight: bold;">✘</span> Al menos 1 carácter especial
          </li>
        </ul>

        <label for="confirmPassword">Confirmar contraseña:</label>
        <input type="password" id="confirmPassword" name="confirmPassword" maxlength="32" class="form-card__input <%= locals.errors && errors.confirmPassword? 'form-card__input--invalid' : null %>">
        <% if(locals.errors && errors.confirmPassword){ %>
        <div class="form-card__error">
          <%= errors.confirmPassword.msg %>
        </div>
        <% } %>
        <ul class="pw-checks" style="list-style: none; padding: 0; margin: 6px 0 0; font-size: 0.9rem;" id="password-match-checks">
          <li id="check-match" style="color: #ea4335; display: none; align-items: center; gap: 6px;">
            <span class="icon" style="font-weight: bold;">✘</span> Las contraseñas coinciden
          </li>
        </ul>

        <label for="image">Imagen de perfil:</label>
        <input type="file" id="image" name="image">
        <% if(locals.errors && errors.image){ %>
        <div class="form-card__error">
          <%= errors.image.msg %>
        </div>
        <% } %>

        <div class="form-card__actions">
          <button type="reset" class="form-card__btn">Borrar</button>
          <button type="submit" class="form-card__btn">Registrarse</button>
        </div>
      </form>
    </div>
  </main>

  <%- include('../partials/footer') %>

  <script src="/js/register.js" defer></script>
</body>

</html>

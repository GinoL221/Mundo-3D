<%- include('../partials/head') %>
<title>Inicia sesión</title>
</head>

<body>
  <%- include('../partials/header') %>

  <main class="form-layout">
    <div class="form-card">
      <form action="/login" method="POST" class="form-card__form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <label for="email">Correo Electrónico:</label>
        <input type="email" class="form-card__input" id="email" name="email" value="<%= typeof oldData !== 'undefined' ? oldData : '' %>" required />

        <label for="password">Contraseña:</label>
        <input type="password" class="form-card__input" id="password" name="password" required />

        <% if(locals.errors){ %>
        <div class="form-card__error">
          <%= errors.password ? errors.password.msg : '' %>
        </div>
        <% } %>

        <label for="remember" class="form-card__checkbox">
          <input type="checkbox" name="remember"> Recuérdame
        </label>

        <button type="submit" class="form-card__btn">Iniciar Sesión</button>
      </form>
    </div>
  </main>

  <%- include('../partials/footer') %>
</body>

</html>

<%- include('../partials/head') %>
<title>Inicia sesión</title>
</head>

<body>
  <%- include('../partials/header') %>

  <main class="form-layout">
    <div class="form-card">
      <form action="/login" method="POST" class="form-card__form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <label for="email">Correo Electrónico:</label>
        <input type="email" class="form-card__input <%= locals.errors && errors.email ? 'form-card__input--invalid' : '' %>" id="email" name="email" value="<%= typeof oldData !== 'undefined' ? oldData : '' %>" />
        <% if(locals.errors && errors.email){ %>
        <div class="form-card__error">
          <%= errors.email.msg %>
        </div>
        <% } %>

        <label for="password">Contraseña:</label>
        <input type="password" class="form-card__input <%= locals.errors && errors.password ? 'form-card__input--invalid' : '' %>" id="password" name="password" />
        <% if(locals.errors && errors.password){ %>
        <div class="form-card__error">
          <%= errors.password.msg %>
        </div>
        <% } %>

        <label for="remember" class="form-card__checkbox">
          <input type="checkbox" name="remember"> Recuérdame
        </label>

        <div class="form-card__actions">
          <button type="submit" class="form-card__btn">Iniciar Sesión</button>
        </div>
      </form>
    </div>
  </main>

  <%- include('../partials/footer') %>
</body>

</html>

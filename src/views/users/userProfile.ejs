<%- include('../partials/head') %>
<title>Tu perfil</title>
</head>

<body class="profile-body">

  <%- include('../partials/header') %>

  <main class="profile">
    <h2>Hola <%= user.FirstName %> </h2>
    <img src="/img/users/<%= user.Image %>" alt="" class="profile__image">
    <p class="profile__email">Email: <strong><%= user.Email %></strong></p>
  </main>

  <%- include('../partials/footer') %>
</body>

</html>
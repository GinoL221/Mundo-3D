<header>
  <div class="container">
    <div class="header-inner">
      <!-- Logo -->
      <a href="/" class="site-logo">
        MUNDO 3D
      </a>

      <!-- Search bar (visual only, non-functional) -->
      <div class="search-bar">
        <input type="text" placeholder="Buscar productos..." aria-label="Buscar productos" />
        <button type="button" aria-label="Buscar">
          <img src="/images/icons/search.png" alt="" width="16" height="16" />
        </button>
      </div>

      <!-- Navigation -->
      <nav class="barra-navegacion">
        <ul class="barra-izquierda">
          <li><a href="/">Inicio</a></li>
          <li><a href="/products">Productos</a></li>
          <% if (locals.isLogged) { %>
          <li><a href="/new-product">Nuevo producto</a></li>
          <% } %>
        </ul>

        <ul class="barra-derecha">
          <% if (locals.isLogged) { %>
          <li class="nav-item">
            <div class="perfil-dropdown">
              <img src="/img/users/<%= locals.userLogged.Image %>" width="32" height="32" alt="Avatar">
              <span class="user-greeting">Hola <%= locals.userLogged.FirstName %></span>
              <ul class="dropdown-menu">
                <li><a href="/profile">Mi perfil</a></li>
                <li><a href="/logout">Cerrar sesi&oacute;n</a></li>
              </ul>
            </div>
          </li>
          <% } else { %>
          <li><a href="/login">Iniciar sesi&oacute;n</a></li>
          <li><a href="/register">Registrarse</a></li>
          <% } %>
          <li>
            <a href="/productCart" class="cart-link" aria-label="Carrito de compras">
              <img src="/images/icons/cart.png" alt="" width="16" height="16" />
              Carrito
              <% if (locals.cartDistinctCount && locals.cartDistinctCount > 0) { %>
              <span class="cart-badge"><%= locals.cartDistinctCount %></span>
              <% } %>
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</header>

<%- include('./partials/head') %>

  <title>Mundo 3D</title>
  </head>

  <body>
    <%- include('./partials/header') %>

      <section class="carousel carousel--lcd" id="homepage-carousel">
        <div class="carousel__container">
          <div class="carousel__slide">
            <a href="/products">
              <div class="carousel__text glow">Modelado y fabricación 3D</div>
            </a>
          </div>
          <div class="carousel__slide">
            <a href="/aboutUs">
              <div class="carousel__text glow">Calidad premium garantizada</div>
            </a>
          </div>
          <div class="carousel__slide">
            <a href="#">
              <div class="carousel__text glow">Pedí tu cotización</div>
            </a>
          </div>
        </div>
        <button class="carousel__prev" aria-label="Slide anterior">&#10094;</button>
        <button class="carousel__next" aria-label="Slide siguiente">&#10095;</button>
        <div class="carousel__indicators">
          <button class="carousel__indicator active" data-slide="0" aria-label="Ir al slide 1"></button>
          <button class="carousel__indicator" data-slide="1" aria-label="Ir al slide 2"></button>
          <button class="carousel__indicator" data-slide="2" aria-label="Ir al slide 3"></button>
        </div>
      </section>

      <main class="index">
        <% if (products && products.length> 0) { %>
          <h2 class="page-heading">Nuestros Seleccionados</h2>
          <div class="product-grid">
            <% products.forEach(function(product) { %>
              <article class="product-card">
                <a href="/products/<%= product.IDProduct %>">
                  <% var catName=product.Category && product.Category.NameCategory ? product.Category.NameCategory
                    : 'Otras' ; %>
                    <img src="/images/illustrations/<%= catName %>.png" alt="<%= catName %>"
                      class="product-card__category-img">
                    <div class="product-card__body">
                      <h3>
                        <%= product.NameProduct %>
                      </h3>
                      <p class="product-card__price">$<%= product.Price %>
                      </p>
                    </div>
                </a>
              </article>
              <% }); %>
          </div>
          <% } else { %>
            <div class="empty-state">
              <img src="/images/illustrations/empty-state.png" alt="Próximamente" class="empty-state-img">
              <h2>Próximamente</h2>
              <p>Estamos preparando productos increíbles para vos.</p>
            </div>
            <% } %>
      </main>

      <%- include('./partials/footer') %>
        <script src="/js/carousel.js"></script>

  </body>

  </html>
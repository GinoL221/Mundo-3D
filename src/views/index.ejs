<%- include('./partials/head') %>

<title>Mundo 3D</title>
</head>

<body>
  <%- include('./partials/header') %>

  <section class="carousel lcd-panel" id="homepage-carousel">
    <div class="carousel-container">
      <div class="carousel-slide">
        <a href="/products">
          <div class="lcd-text glow">Modelado y fabricación 3D</div>
        </a>
      </div>
      <div class="carousel-slide">
        <a href="/aboutUs">
          <div class="lcd-text glow">Calidad premium garantizada</div>
        </a>
      </div>
      <div class="carousel-slide">
        <a href="#">
          <div class="lcd-text glow">Pedí tu cotización</div>
        </a>
      </div>
    </div>
    <button class="carousel-prev" aria-label="Slide anterior">&#10094;</button>
    <button class="carousel-next" aria-label="Slide siguiente">&#10095;</button>
    <div class="carousel-indicators">
      <button class="indicator active" data-slide="0" aria-label="Ir al slide 1"></button>
      <button class="indicator" data-slide="1" aria-label="Ir al slide 2"></button>
      <button class="indicator" data-slide="2" aria-label="Ir al slide 3"></button>
    </div>
  </section>

  <main class="index">
    <% if (products && products.length > 0) { %>
      <h2 class="titulo">Nuestros Seleccionados</h2>
      <div class="products_container">
        <% products.forEach(function(product) { %>
          <article class="product_container">
            <a href="/products/<%= product.IDProduct %>">
              <% var catName = product.Category && product.Category.NameCategory ? product.Category.NameCategory : 'Otras'; %>
              <img src="/images/illustrations/<%= catName %>.png" alt="<%= catName %>" class="product-category-img">
              <div class="info_produc">
                <h3><%= product.NameProduct %></h3>
                <p class="price">$<%= product.Price %></p>
              </div>
            </a>
          </article>
        <% }); %>
      </div>
    <% } else { %>
      <div class="empty-state">
        <img src="/images/illustrations/empty-state.png" alt="Próximamente" class="empty-state-img">
        <h2>Próximamente</h2>
        <p>Estamos preparando productos increíbles para vos.</p>
      </div>
    <% } %>
  </main>

  <%- include('./partials/footer') %>
  <script src="/js/carousel.js"></script>

</body>

</html>

<%- include('../partials/head') %>

  <title>Detalles del Producto</title>
  </head>

  <body>

    <%- include('../partials/header') %>

      <h2 class="product-detail__title">Detalles del Producto</h2>

      <main class="product-detail__main">
        <div class="product-detail__card">
          <a href="/products" class="product-detail__back-link">← Volver a productos</a>
          <img src="/img/products/<%= product.Image %>" alt="<%= product.NameProduct %>" class="product-detail__image">
          <section class="product-detail__info">
            <h3>
              <%= product.NameProduct %>
            </h3>
            <p class="price price--lg">Precio: $<%= product.Price %>
            </p>
            <p>
              <%= product.DescriptionProduct %>
            </p>
            <a href="/productCart?action=buy" class="product-detail__action">COMPRAR</a>
            <a href="/productCart?action=add" class="product-detail__action product-detail__action--secondary">AGREGAR AL CARRITO</a>
          </section>
        </div>
      </main>

      <%- include('../partials/footer') %>
  </body>

  </html>
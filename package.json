{
  "name": "mundo-3d",
  "version": "1.0.0",
  "description": "\"Mundo3D\" es un ecommerce que se especializa en proporcionar productos personalizados y únicos utilizando la tecnología de impresión 3D. Los clientes pueden explorar, diseñar y adquirir una variedad de objetos, desde elementos decorativos hasta prototipos funcionales, con opciones para elegir diseños, colores y materiales.",
  "main": "app.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "frontend:dev": "pnpm --filter frontend dev",
    "frontend:build": "pnpm --filter frontend build",
    "test": "jest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.js\"",
    "type-check": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Grupo-7-DH/Mundo-3D.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=22"
  },
  "bugs": {
    "url": "https://github.com/Grupo-7-DH/Mundo-3D/issues"
  },
  "homepage": "https://github.com/Grupo-7-DH/Mundo-3D#readme",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-rate-limit": "8.5.2",
    "express-session": "^1.18.0",
    "express-validator": "^7.0.1",
    "helmet": "8.2.0",
    "jsonwebtoken": "^9.0.2",
    "method-override": "^3.0.0",
    "multer": "^2.0.2",
    "mysql2": "^3.9.7",
    "pino": "10.3.1",
    "sequelize": "^6.37.3",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "25.9.2",
    "@types/sequelize": "4.28.20",
    "eslint": "10.4.1",
    "eslint-config-prettier": "^10.0.1",
    "globals": "17.6.0",
    "jest": "30.4.2",
    "nodemon": "^3.1.0",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.3",
    "supertest": "7.2.2",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.24.0"
  }
}
